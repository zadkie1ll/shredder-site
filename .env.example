SHREDDER_SITE_ENV=production
SHREDDER_SITE_PORT=8010
SHREDDER_SITE_PUBLIC_BASE_URL=https://shredder.example
SHREDDER_SITE_SESSION_SECRET=change-me-to-a-long-random-secret

# Legacy fallback password for users without a personal site password.
SHREDDER_SITE_LOGIN_PASSWORD=change-me
SHREDDER_SITE_TRIAL_PERIOD_DAYS=7
SHREDDER_SITE_REGISTRATION_CODE_TTL_SECONDS=900

SHREDDER_SITE_SMTP_HOST=smtp.example.com
SHREDDER_SITE_SMTP_PORT=587
SHREDDER_SITE_SMTP_USERNAME=
SHREDDER_SITE_SMTP_PASSWORD=
SHREDDER_SITE_SMTP_FROM_EMAIL=no-reply@orpheous.ru
SHREDDER_SITE_SMTP_USE_TLS=true

SHREDDER_SITE_TELEGRAM_BOT_USERNAME=
SHREDDER_SITE_TELEGRAM_BOT_TOKEN=
SHREDDER_SITE_TELEGRAM_LINK_BONUS_DAYS=7
SHREDDER_SITE_TELEGRAM_LOGIN_MAX_AGE_SECONDS=86400

SHREDDER_SITE_YOOKASSA_SHOP_ID=
SHREDDER_SITE_YOOKASSA_SECRET=
SHREDDER_SITE_RECEIPT_EMAIL=receipts@orpheous.ru

# Option A: direct SQLAlchemy URL to the shared Postgres DB used by common/alembic.
SHREDDER_SITE_DATABASE_URL=postgresql+psycopg2://user:password@postgres-host:5432/dbname

# Option B: use the same variables as the bot instead of SHREDDER_SITE_DATABASE_URL.
# MI_VPN_BOT_POSTGRES_HOST=postgres-host
# MI_VPN_BOT_POSTGRES_PORT=5432
# MI_VPN_BOT_POSTGRES_USER=user
# MI_VPN_BOT_POSTGRES_PASSWORD=password
# MI_VPN_BOT_POSTGRES_DB=dbname

# RWMS/Remnawave gRPC endpoint. The MI_VPN_BOT_* names are also supported.
SHREDDER_SITE_RWMS_ADDR=rwms-host
SHREDDER_SITE_RWMS_PORT=50051
SHREDDER_SITE_LEGACY_LIMITED_SUBSCRIPTION_ENABLED=false
SHREDDER_SITE_INTERNAL_SQUADS_UUIDS=
# MI_VPN_BOT_RWMS_ADDR=rwms-host
# MI_VPN_BOT_RWMS_PORT=50051
